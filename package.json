    "p-limit": "^6.1.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "sharp": "^0.33.0",
    "winston": "^3.14.0"
  },
