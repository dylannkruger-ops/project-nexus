# ═══════════════════════════════════════════════════════
# KRONOS AI — ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in your keys
# ═══════════════════════════════════════════════════════

# ──── CORE AI ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ──── NANO BANANA PRO (Google Gemini Image) ───────────
GOOGLE_API_KEY=AIza...

# ──── KLING 2.6 VIDEO (via PiAPI) ─────────────────────
PIAPI_KEY=...
# Alternative provider: KIEAI_API_KEY=...

# ──── INFRASTRUCTURE ──────────────────────────────────
REDIS_URL=redis://localhost:6379
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=kronos-memory
DATABASE_URL=postgresql://postgres:password@localhost:5432/kronos

# ──── SERVER ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
ASSETS_DIR=./assets

# ──── AGENT CONFIG ────────────────────────────────────
MAX_CONCURRENT_AGENTS=20
AGENT_TIMEOUT_MS=120000

# ──── CLAUDE COWORK (DESKTOP CONTROL) ─────────────────
COWORK_ENABLED=false
COWORK_MCP_URL=http://localhost:8765

# ──── SOCIAL: TIKTOK ──────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ──── SOCIAL: META (INSTAGRAM + FACEBOOK) ─────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_INSTAGRAM_USER_ID=
META_PAGE_ID=

# ──── SOCIAL: YOUTUBE ─────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ──── SOCIAL: TWITTER / X ─────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ──── SOCIAL: LINKEDIN ────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:...

# ──── SOCIAL: PINTEREST ───────────────────────────────
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
